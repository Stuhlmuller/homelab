# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

.terragrunt-cache/
.DS_Store
.pytest_cache/
__pycache__/
*.pyc
plan.out
*.log
.env
.env.*
.kube/
kubeconfig*
*.secret.yaml
secrets/
*.key
*.crt

# Kubernetes and local cluster credentials
*.secret.yaml
secrets/
.kube/
kubeconfig*
.talos/talosconfig
*.key
*.crt

# Python bytecode
__pycache__/
*.py[cod]

#Ignore vscode AI rules
.github/copilot-instructions.md

# Obsidian local workspace state
docs/knowledge-base/.obsidian/workspace*.json
docs/knowledge-base/.obsidian/plugins/
docs/knowledge-base/.obsidian/snippets/
docs/knowledge-base/.trash/
# Talos generated/local credential material
.talos/secrets.yaml
.talos/controlplane.yaml
.talos/worker.yaml
.talos/*.kubeconfig
.talos/*talosconfig*
talosconfig
talos-secrets.yaml

# Common local private key, certificate, and token material
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519
token.txt
*.token
