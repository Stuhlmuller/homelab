{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": false,
  "packageRules": [
    {
      "description": "Image updates are owned by Argo CD Image Updater.",
      "matchManagers": ["helm-values"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["adinhodovic/compass", "ghcr.io/n8n-io/n8n"],
      "matchFileNames": [
        "clusters/homelab/apps/compass/values.yaml",
        "clusters/homelab/apps/n8n/values.yaml"
      ],
      "enabled": false
    }
  ],
  "lockFileMaintenance": {
    "enabled": true
  }
}
