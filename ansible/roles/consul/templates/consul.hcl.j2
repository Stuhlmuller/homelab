datacenter = "{{ consul_datacenter }}"
data_dir   = "{{ consul_data_dir }}"
bind_addr  = "{{ ansible_host }}"
client_addr = "0.0.0.0"
node_name  = "{{ consul_node_name }}"
server     = true
bootstrap_expect = {{ consul_bootstrap_expect }}
ui_config {
  enabled = true
}

retry_join = [{% for member in consul_retry_join %}"{{ member }}"{% if not loop.last %}, {% endif %}{% endfor %}]

ports {
  grpc = -1
}
